# 阅读次数配置 (默认40次/20分钟)
READ_NUM=40

# 微信读书 curl bash 命令 (必需)
# 获取方式：
# 1. 打开微信读书网页版 https://weread.qq.com/
# 2. 打开浏览器开发者工具 (F12)
# 3. 切换到 Network 标签
# 4. 开始阅读任意书籍
# 5. 找到 'read' 请求，右键选择 "Copy as cURL (bash)"
# 6. 将完整的 curl 命令粘贴到下面
WXREAD_CURL_BASH=curl 'https://weread.qq.com/web/book/read' -H 'accept: application/json, text/plain, */*' -H 'cookie: YOUR_COOKIES_HERE' -H 'user-agent: Mozilla/5.0'

# 推送方式 (可选)
# 支持: pushplus, wxpusher, telegram, serverchan
PUSH_METHOD=

# PushPlus 推送配置 (可选)
# 官网: https://www.pushplus.plus/
PUSHPLUS_TOKEN=

# Telegram 推送配置 (可选)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WxPusher 推送配置 (可选)
# 官网: https://wxpusher.zjiecode.com/
WXPUSHER_SPT=

# ServerChan 推送配置 (可选)
# 官网: https://sct.ftqq.com/
SERVERCHAN_SPT=

# 定时任务配置 (Cron 表达式格式)
# 默认每天凌晨1点执行: 0 1 * * *
# 其他示例:
#   每6小时: 0 */6 * * *
#   每天早上8:30: 30 8 * * *
#   每天中午12点: 0 12 * * *
CRON_SCHEDULE=0 1 * * *
